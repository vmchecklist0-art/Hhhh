# Neon PostgreSQL credentials template - safe to commit
# Copy this file to .env and fill in your values
DATABASE_URL='postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require'

# ImgBB upload key for secure image uploads from the app
# Create a free account at https://imgbb.com and generate a key.
IMGBB_API_KEY=your_imgbb_api_key

# Google Maps API Key - required for map features
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
